import matplotlib.pyplot as plt

# 1. Plot Price and the 'Trap' Signal
plt.figure(figsize=(15, 7))
plt.plot(df['price'], label='Asset Price', color='black', alpha=0.7)

# 2. Highlight Absorption Zones (The Trap)
absorption_points = df[df['is_absorption'] == 1]
plt.scatter(absorption_points.index, absorption_points['price'], 
            color='red', label='Absorption (Institutional Trap)', marker='x')

# 3. Highlight the Entry Signal (The Reclaim)
entry_points = df[df['signal'] == 1]
plt.scatter(entry_points.index, entry_points['price'], 
            color='green', label='Buy Signal (Reclaim)', s=100)

plt.title('Institutional Liquidity Sweep & Reclaim Pattern')
plt.legend()
plt.show()
